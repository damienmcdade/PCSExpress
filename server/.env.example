# PCS Express — Express API (Railway) environment.
# This reflects what server/index.js ACTUALLY reads. The app has NO database,
# auth, S3, or SMTP — all user data is encrypted client-side, the server is
# metadata-only. (A prior version of this file documented Postgres/JWT/AWS/
# SMTP that the server never uses — removed.)

# --- Core ---
PORT=3001
NODE_ENV=production
# HOST defaults to 0.0.0.0 (required for Railway); rarely overridden.

# --- Origin allowlist (security-critical) ---
# Comma-separated origins allowed to make write (POST) requests, IN ADDITION
# to the built-in defaults (https://pcsexpress.app, https://www.pcsexpress.app)
# and the Capacitor/localhost shells. Set this to add a staging/preview domain.
# Leaving it unset is SAFE — the production web app works on the defaults.
# CORS_ORIGINS=https://staging.pcsexpress.app

# --- AI assistant (Anthropic) ---
# Without ANTHROPIC_API_KEY the AI endpoints return 501 and the client falls
# back to the curated JTR/FTR/DSSR knowledge base.
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Global hourly ceiling on total AI calls across all IPs (cost backstop).
# AI_GLOBAL_HOURLY_CAP=1000

# --- Optional upstream data providers (each feature hides if its key is unset) ---
# SAM_API_KEY=            # SAM.gov veteran-owned business search
# RAPIDAPI_KEY=           # housing listings
# RAPIDAPI_HOST=
# RAPIDAPI_PATH=
# FRED_API_KEY=           # mortgage / market stats
# HUD_API_KEY=            # fair market rents
# USAJOBS_API_KEY=        # federal job listings
# USAJOBS_USER_AGENT=info@cyberwaveglobal.com   # must match the registered key owner

# --- Push notifications (VAPID; feature disabled if unset) ---
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:info@cyberwaveglobal.com
