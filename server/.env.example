# PCS Express - Environment Configuration

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/pcs_express
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pcs_express
DB_USER=pcs_express
DB_PASSWORD=secure_password

# Server
PORT=3001
NODE_ENV=production

# JWT
JWT_SECRET=your-super-secure-jwt-secret-key-change-in-production

# AWS S3 (for document storage)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_S3_BUCKET=pcs-express-documents
AWS_REGION=us-east-1

# Email (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@cyberwaveglobal.com
SMTP_PASSWORD=smtp_password

# API
API_BASE_URL=https://api.pcs-express.mil
FRONTEND_URL=https://pcs-express-production.up.railway.app

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
