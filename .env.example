# ─── PCS Express Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────
# Your Anthropic API key — get one at console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Server ────────────────────────────────────────────────────────────────────
# Port for the Express API server (default: 3001)
PORT=3001

# Node environment: development | production
NODE_ENV=development

# ── Production only ───────────────────────────────────────────────────────────
# Extra origins allowed to POST to /api/* (comma-separated), IN ADDITION to the
# built-in defaults (pcsexpress.app + www) and the Capacitor/localhost shells.
# The variable the server actually reads is CORS_ORIGINS (NOT ALLOWED_ORIGIN).
# Safe to leave unset — production works on the defaults.
# CORS_ORIGINS=https://staging.pcsexpress.app
# Optional global hourly cap on total AI requests (cost backstop; default 1000):
# AI_GLOBAL_HOURLY_CAP=1000

# ── Optional: Home Locator Market Snapshot ────────────────────────────────────
# Both are FREE keys. The Market Snapshot panel stays hidden when either
# key is absent, so the app degrades gracefully.
#
# FRED — Federal Reserve Economic Data. Instant signup.
# https://fred.stlouisfed.org/docs/api/api_key.html
# Unlocks: 30-yr mortgage rate, US median home price, Case-Shiller HPI.
# FRED_API_KEY=

# HUD User — Fair Market Rents by bedroom count. ~24h approval after signup.
# https://www.huduser.gov/portal/dataset/fmr-api.html
# Unlocks: efficiency / 1BR / 2BR / 3BR / 4BR FMRs matched to your city.
# HUD_API_KEY=

# ── Optional: Live rentals (paid) ─────────────────────────────────────────────
# RapidAPI proxy for priced rental listings. Skipped when unset.
# RAPIDAPI_KEY=
# RAPIDAPI_HOST=realty-mole-property-api.p.rapidapi.com
# RAPIDAPI_PATH=/rentalListings

# ── Optional: Web Push ────────────────────────────────────────────────────────
# Generate the keypair once: `npx web-push generate-vapid-keys --json`
# With both keys set, /api/push-config serves the public key, clients can
# subscribe, and POST /api/push-dispatch can broadcast. See docs/PUSH_SETUP.md.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=                      # KEEP SECRET — signs every push
# VAPID_SUBJECT=mailto:info@cyberwaveglobal.com
# Shared secret authorizing POST /api/push-dispatch (Authorization: Bearer …,
# or X-Push-Dispatch-Key). UNSET = dispatch endpoint hard-disabled (503).
# PUSH_DISPATCH_KEY=

# ── Optional: Jobs ────────────────────────────────────────────────────────────
# USAJOBS — federal civilian jobs near gaining installation. Free signup.
# https://developer.usajobs.gov/
# Set USAJOBS_USER_AGENT to the SAME email you registered the API key
# with on developer.usajobs.gov — USAJOBS validates the User-Agent
# against the key owner. In production set both explicitly; the code
# default (info@cyberwaveglobal.com) is only a fallback.
# USAJOBS_API_KEY=
# USAJOBS_USER_AGENT=info@cyberwaveglobal.com

# ── Android release signing (local only; do NOT commit real values) ───────────
# Used by android/app/build.gradle when running `npm run android:bundle`.
# Keystore lives at ~/pcsexpress-upload-key.jks (not in repo).
# ANDROID_KEYSTORE_PASSWORD=
# ANDROID_KEY_ALIAS=pcsexpress-upload
# ANDROID_KEY_PASSWORD=
