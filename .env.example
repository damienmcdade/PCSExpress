# ─── PCS Express Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────
# Your Anthropic API key — get one at console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Server ────────────────────────────────────────────────────────────────────
# Port for the Express API server (default: 3001)
PORT=3001

# Node environment: development | production
NODE_ENV=development

# ── Production only ───────────────────────────────────────────────────────────
# Your deployed frontend URL — used for CORS in production
# ALLOWED_ORIGIN=https://your-domain.com

# ── Optional: Home Locator Market Snapshot ────────────────────────────────────
# Both are FREE keys. The Market Snapshot panel stays hidden when either
# key is absent, so the app degrades gracefully.
#
# FRED — Federal Reserve Economic Data. Instant signup.
# https://fred.stlouisfed.org/docs/api/api_key.html
# Unlocks: 30-yr mortgage rate, US median home price, Case-Shiller HPI.
# FRED_API_KEY=

# HUD User — Fair Market Rents by bedroom count. ~24h approval after signup.
# https://www.huduser.gov/portal/dataset/fmr-api.html
# Unlocks: efficiency / 1BR / 2BR / 3BR / 4BR FMRs matched to your city.
# HUD_API_KEY=

# ── Optional: Live rentals (paid) ─────────────────────────────────────────────
# RapidAPI proxy for priced rental listings. Skipped when unset.
# RAPIDAPI_KEY=
# RAPIDAPI_HOST=realty-mole-property-api.p.rapidapi.com
# RAPIDAPI_PATH=/rentalListings

# ── Optional: Jobs ────────────────────────────────────────────────────────────
# USAJOBS — federal civilian jobs near gaining installation. Free signup.
# https://developer.usajobs.gov/
# USAJOBS_API_KEY=
# USAJOBS_USER_AGENT=your-email@example.com

# ── Android release signing (local only; do NOT commit real values) ───────────
# Used by android/app/build.gradle when running `npm run android:bundle`.
# Keystore lives at ~/pcsexpress-upload-key.jks (not in repo).
# ANDROID_KEYSTORE_PASSWORD=
# ANDROID_KEY_ALIAS=pcsexpress-upload
# ANDROID_KEY_PASSWORD=
