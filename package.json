{
  "name": "pcs-express",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "PCS Express — personalized PCS guidance for U.S. service members",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "nodemon server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/index.js",
    "smoke": "playwright test scripts/smoke-check.spec.cjs --browser=chromium --reporter=line",
    "ios:build": "npm run build && npx cap sync ios && echo 'iOS build synced. Open with: open ios/App/App.xcworkspace'",
    "ios:open": "open ios/App/App.xcworkspace",
    "cap:sync": "npx cap sync ios",
    "android:sync": "npm run build && npx cap sync android",
    "android:open": "npx cap open android",
    "android:bundle": "npm run build && npx cap sync android && cd android && ./gradlew bundleRelease",
    "deploy:vercel": "bash scripts/deploy-retry.sh vercel deploy --prod --yes",
    "deploy:railway": "bash scripts/deploy-retry.sh railway up --service PCSExpress --ci",
    "deploy:all": "npm run deploy:vercel && npm run deploy:railway"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "debug": "^4.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "postcss": "^8.5.13",
    "rollup": "^4.60.2"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^8.2.2",
    "leaflet": "^1.9.4",
    "nodemon": "^3.1.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^8.0.13"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
