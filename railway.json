{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "dockerfile": "Dockerfile"
  },
  "deploy": {
    "startCommand": "node server/index.js",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 5,
    "healthCheck": {
      "command": "wget --quiet --tries=1 --spider http://localhost:3001/api/health || exit 1",
      "interval": 30,
      "timeout": 3,
      "retries": 3,
      "startPeriod": 10
    }
  }
}
