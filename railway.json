{
  "$schema": "railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "dockerfile": "Dockerfile"
  },
  "deploy": {
    "startCommand": "node server/manager.js",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 1,
    "healthCheck": {
      "command": "curl --fail --silent --show-error http://localhost:3001/health || exit 1",
      "interval": 30,
      "timeout": 5,
      "retries": 2,
      "startPeriod": 20
    }
  }
}
